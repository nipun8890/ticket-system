# Secret key used to sign and verify JWTs. Set this to a long, random,
# secret value in any real deployment. If unset, the app falls back to an
# insecure default and prints a warning (fine for quick local testing only).
JWT_SECRET=change-this-to-a-long-random-secret

# Port the HTTP server listens on. Defaults to 8080 if unset.
PORT=8080
